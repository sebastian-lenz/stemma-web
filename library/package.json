{
  "name": "stemma-web",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/stemma-web.umd.cjs",
  "module": "./dist/stemma-web.js",
  "exports": {
    ".": {
      "import": "./dist/stemma-web.js",
      "require": "./dist/stemma-web.umd.cjs"
    },
    "./p5": "./dist/stemma-web.p5.js"
  },
  "types": "./dist/stemma-web.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && vite build --config vite.config.p5.js",
    "build-proto": "./bin/proto",
    "preview": "vite preview"
  },
  "devDependencies": {
    "@types/p5": "^1.7.7",
    "@types/w3c-web-usb": "^1.0.14",
    "protobufjs": "^8.0.1",
    "protobufjs-cli": "^2.0.1",
    "typescript": "^5.9.3",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.0.0"
  }
}
