{
  "name": "stemma-web",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/stemma-web.umd.cjs",
  "module": "./dist/stemma-web.js",
  "exports": {
    ".": {
      "import": "./dist/stemma-web.js",
      "require": "./dist/stemma-web.umd.cjs"
    }
  },
  "types": "./dist/stemma-web.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build-proto": "pbjs -t static-module -w es6 --es6 --path ../proto ../proto/messages.proto -o src/proto/messages.js && pbts src/proto/messages.js -o src/proto/messages.d.ts",
    "preview": "vite preview"
  },
  "devDependencies": {
    "@types/w3c-web-usb": "^1.0.14",
    "protobufjs": "^7.5.4",
    "protobufjs-cli": "^2.0.0",
    "typescript": "^5.0.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^1.0.5"
  }
}
